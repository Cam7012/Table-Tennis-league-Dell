<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Table Tennis League 2025</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0e0e0e;
    --surface: #171717;
    --surface2: #202020;
    --border: #2a2a2a;
    --border2: #333;
    --text: #f0ede8;
    --muted: #666;
    --accent: #c8f04a;
    --win-bg: rgba(200,240,74,0.08);
    --gold: #f5c842;
    --silver: #999;
    --bronze: #c87c42;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); color: var(--text); font-family: 'Syne', sans-serif; min-height: 100vh; padding: 2rem 1rem 4rem; }

  .header { max-width: 720px; margin: 0 auto 2.5rem; display: flex; align-items: flex-end; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
  .header h1 { font-size: clamp(2rem, 6vw, 3.2rem); font-weight: 800; line-height: 1; letter-spacing: -0.03em; }
  .header h1 span { color: var(--accent); }
  .header p { font-family: 'DM Mono', monospace; font-size: 12px; color: var(--muted); margin-top: 8px; letter-spacing: 0.05em; text-transform: uppercase; }
  .progress-pill { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--accent); background: var(--win-bg); border: 1px solid rgba(200,240,74,0.2); border-radius: 100px; padding: 6px 14px; white-space: nowrap; }

  .tabs { max-width: 720px; margin: 0 auto 2rem; display: flex; gap: 4px; background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 4px; }
  .tab { flex: 1; padding: 10px; border: none; border-radius: 7px; background: transparent; color: var(--muted); font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 600; cursor: pointer; transition: all 0.15s; }
  .tab.active { background: var(--surface2); color: var(--text); border: 1px solid var(--border2); }

  .section { display: none; max-width: 720px; margin: 0 auto; }
  .section.active { display: block; }

  .day-block { margin-bottom: 2rem; }
  .day-label { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 10px; display: flex; align-items: center; gap: 10px; }
  .day-label::after { content: ''; flex: 1; height: 1px; background: var(--border); }

  .match-card { display: flex; align-items: center; gap: 10px; padding: 12px 14px; background: var(--surface); border: 1px solid var(--border); border-radius: 10px; margin-bottom: 8px; transition: border-color 0.2s; }
  .match-card.done { border-color: rgba(200,240,74,0.2); }
  .match-num { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--muted); min-width: 28px; }

  .match-players { display: flex; align-items: center; gap: 8px; flex: 1; min-width: 0; overflow: hidden; }
  .player-name { font-size: 14px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; transition: color 0.2s; }
  .player-name.winner-name { color: var(--accent); }
  .player-name.loser-name { color: var(--muted); }
  .vs { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--muted); flex-shrink: 0; }

  .score-area { display: flex; align-items: center; gap: 6px; flex-shrink: 0; }
  .score-input {
    width: 44px; height: 38px;
    background: var(--surface2);
    border: 1px solid var(--border2);
    border-radius: 7px;
    color: var(--text);
    font-family: 'DM Mono', monospace;
    font-size: 17px;
    font-weight: 500;
    text-align: center;
    -moz-appearance: textfield;
    appearance: textfield;
    transition: border-color 0.2s, background 0.2s, color 0.2s;
  }
  .score-input::-webkit-outer-spin-button,
  .score-input::-webkit-inner-spin-button { -webkit-appearance: none; }
  .score-input:focus { outline: none; border-color: rgba(200,240,74,0.5); }
  .score-input.win-score { border-color: var(--accent); color: var(--accent); background: var(--win-bg); }
  .score-sep { font-family: 'DM Mono', monospace; font-size: 14px; color: var(--muted); }
  .reset-btn { background: none; border: none; color: var(--muted); cursor: pointer; font-size: 13px; padding: 4px 6px; border-radius: 4px; transition: color 0.15s; }
  .reset-btn:hover { color: var(--text); }

  .hint { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--muted); margin-bottom: 1.5rem; }

  /* League table */
  .table-wrap { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
  table { width: 100%; border-collapse: collapse; font-size: 14px; }
  thead tr { background: var(--surface2); border-bottom: 1px solid var(--border2); }
  th { padding: 12px 14px; text-align: left; font-family: 'DM Mono', monospace; font-size: 11px; font-weight: 400; color: var(--muted); letter-spacing: 0.08em; text-transform: uppercase; }
  th.right, td.right { text-align: right; }
  td { padding: 13px 14px; border-bottom: 1px solid var(--border); color: var(--text); font-weight: 600; }
  tbody tr:last-child td { border-bottom: none; }
  tbody tr:hover { background: var(--surface2); }

  .rank-cell { font-family: 'DM Mono', monospace; font-size: 13px; font-weight: 400; width: 32px; }
  .rank-1 { color: var(--gold); }
  .rank-2 { color: var(--silver); }
  .rank-3 { color: var(--bronze); }
  .pts-cell { font-family: 'DM Mono', monospace; font-size: 15px; color: var(--accent); }
  .stat-cell { font-family: 'DM Mono', monospace; font-size: 13px; color: var(--muted); font-weight: 400; }
  .gd-pos { color: var(--accent); }
  .gd-neg { color: #e05a5a; }

  .player-cell { display: flex; align-items: center; gap: 10px; }
  .avatar { width: 30px; height: 30px; border-radius: 50%; background: var(--surface2); border: 1px solid var(--border2); display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 700; color: var(--accent); font-family: 'DM Mono', monospace; flex-shrink: 0; }
  .leader-bar { height: 2px; background: var(--accent); border-radius: 2px; margin-top: 3px; transition: width 0.4s ease; }
  .name-wrap { display: flex; flex-direction: column; }
  .name-wrap span { font-size: 14px; }

  @media (max-width: 480px) {
    .score-input { width: 40px; height: 36px; font-size: 16px; }
    .match-card { gap: 8px; padding: 10px 12px; }
    .player-name { font-size: 13px; }
  }
</style>
</head>
<body>

<div class="header">
  <div>
    <h1>Table Tennis<br><span>League</span></h1>
    <p>6 players &middot; Round robin &middot; Best of 1</p>
  </div>
  <div class="progress-pill" id="progress-pill">0 / 15 played</div>
</div>

<div class="tabs">
  <button class="tab active" onclick="showTab('schedule',event)">Schedule</button>
  <button class="tab" onclick="showTab('table',event)">League table</button>
</div>

<div id="schedule" class="section active">
  <p class="hint">Type in the scores — winner is set automatically. Higher score wins.</p>
  <div id="schedule-content"></div>
</div>

<div id="table" class="section">
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Player</th>
          <th class="right">P</th>
          <th class="right">W</th>
          <th class="right">L</th>
          <th class="right">GD</th>
          <th class="right">Pts</th>
        </tr>
      </thead>
      <tbody id="table-body"></tbody>
    </table>
  </div>
</div>

<script>
const players = ['Nathan','James','Emann','Jack','Cam','Rory'];
const dayNames = ['Monday','Tuesday','Wednesday','Thursday','Friday'];

const fixed = players[0];
const rotating = players.slice(1);
const matches = [];
let id = 0;

for (let r = 0; r < 5; r++) {
  const round = [[fixed, rotating[0]]];
  for (let i = 1; i < rotating.length; i++) {
    const opp = rotating[rotating.length - i];
    if (opp) round.push([rotating[i], opp]);
  }
  round.forEach((pair, mi) => {
    matches.push({ id: id++, day: r+1, matchNum: mi+1, p1: pair[0], p2: pair[1], s1: null, s2: null });
  });
  rotating.unshift(rotating.pop());
}

function save() {
  try { localStorage.setItem('tt_scores_v2', JSON.stringify(matches.map(m => ({ s1: m.s1, s2: m.s2 })))); } catch(e) {}
}
function load() {
  try {
    const d = JSON.parse(localStorage.getItem('tt_scores_v2') || 'null');
    if (d) d.forEach((s, i) => { if (matches[i]) { matches[i].s1 = s.s1; matches[i].s2 = s.s2; } });
  } catch(e) {}
}
load();

function getWinner(m) {
  if (m.s1 === null || m.s2 === null) return null;
  if (m.s1 === m.s2) return null;
  return m.s1 > m.s2 ? m.p1 : m.p2;
}

function onScoreChange(matchId, which, val) {
  const parsed = val === '' ? null : parseInt(val, 10);
  matches[matchId][which] = (isNaN(parsed) || parsed < 0) ? null : parsed;
  save();
  updateCardState(matchId);
  renderTable();
}

function resetMatch(matchId) {
  matches[matchId].s1 = null;
  matches[matchId].s2 = null;
  const s1el = document.getElementById('s1-' + matchId);
  const s2el = document.getElementById('s2-' + matchId);
  if (s1el) s1el.value = '';
  if (s2el) s2el.value = '';
  save();
  updateCardState(matchId);
  renderTable();
}

function updateCardState(matchId) {
  const m = matches[matchId];
  const winner = getWinner(m);
  const hasScores = m.s1 !== null || m.s2 !== null;

  const card = document.getElementById('card-' + matchId);
  if (card) card.classList.toggle('done', winner !== null);

  const s1el = document.getElementById('s1-' + matchId);
  const s2el = document.getElementById('s2-' + matchId);
  if (s1el) s1el.className = 'score-input' + (winner === m.p1 ? ' win-score' : '');
  if (s2el) s2el.className = 'score-input' + (winner === m.p2 ? ' win-score' : '');

  const p1el = document.getElementById('p1-' + matchId);
  const p2el = document.getElementById('p2-' + matchId);
  if (p1el) p1el.className = 'player-name' + (winner === m.p1 ? ' winner-name' : winner === m.p2 ? ' loser-name' : '');
  if (p2el) p2el.className = 'player-name' + (winner === m.p2 ? ' winner-name' : winner === m.p1 ? ' loser-name' : '');

  const resetEl = document.getElementById('reset-' + matchId);
  if (resetEl) resetEl.style.display = hasScores ? 'inline' : 'none';

  // update progress
  const played = matches.filter(mm => getWinner(mm) !== null).length;
  document.getElementById('progress-pill').textContent = played + ' / ' + matches.length + ' played';
}

function renderSchedule() {
  const played = matches.filter(m => getWinner(m) !== null).length;
  document.getElementById('progress-pill').textContent = played + ' / ' + matches.length + ' played';
  let html = '';
  for (let d = 1; d <= 5; d++) {
    const dayMatches = matches.filter(m => m.day === d);
    html += '<div class="day-block"><div class="day-label">Day ' + d + ' &mdash; ' + dayNames[d-1] + '</div>';
    dayMatches.forEach((m, mi) => {
      const winner = getWinner(m);
      const hasScores = m.s1 !== null || m.s2 !== null;
      const p1cls = winner === m.p1 ? ' winner-name' : winner === m.p2 ? ' loser-name' : '';
      const p2cls = winner === m.p2 ? ' winner-name' : winner === m.p1 ? ' loser-name' : '';
      const s1cls = winner === m.p1 ? ' win-score' : '';
      const s2cls = winner === m.p2 ? ' win-score' : '';
      html += '<div class="match-card' + (winner ? ' done' : '') + '" id="card-' + m.id + '">' +
        '<span class="match-num">M' + (mi+1) + '</span>' +
        '<span class="match-players">' +
          '<span class="player-name' + p1cls + '" id="p1-' + m.id + '">' + m.p1 + '</span>' +
          '<span class="vs">vs</span>' +
          '<span class="player-name' + p2cls + '" id="p2-' + m.id + '">' + m.p2 + '</span>' +
        '</span>' +
        '<div class="score-area">' +
          '<input class="score-input' + s1cls + '" id="s1-' + m.id + '" type="number" min="0" max="99" placeholder="0"' +
            ' value="' + (m.s1 !== null ? m.s1 : '') + '"' +
            ' oninput="onScoreChange(' + m.id + ',\'s1\',this.value)" />' +
          '<span class="score-sep">:</span>' +
          '<input class="score-input' + s2cls + '" id="s2-' + m.id + '" type="number" min="0" max="99" placeholder="0"' +
            ' value="' + (m.s2 !== null ? m.s2 : '') + '"' +
            ' oninput="onScoreChange(' + m.id + ',\'s2\',this.value)" />' +
          '<button class="reset-btn" id="reset-' + m.id + '" onclick="resetMatch(' + m.id + ')" title="Clear" style="display:' + (hasScores ? 'inline' : 'none') + '">&#x2715;</button>' +
        '</div>' +
      '</div>';
    });
    html += '</div>';
  }
  document.getElementById('schedule-content').innerHTML = html;
}

function renderTable() {
  const stats = {};
  players.forEach(p => { stats[p] = { p:0, w:0, l:0, gf:0, ga:0, pts:0 }; });
  matches.forEach(m => {
    const winner = getWinner(m);
    if (winner !== null) {
      const loser = winner === m.p1 ? m.p2 : m.p1;
      const ws = winner === m.p1 ? m.s1 : m.s2;
      const ls = winner === m.p1 ? m.s2 : m.s1;
      stats[winner].p++; stats[winner].w++; stats[winner].pts++;
      stats[winner].gf += ws; stats[winner].ga += ls;
      stats[loser].p++; stats[loser].l++;
      stats[loser].gf += ls; stats[loser].ga += ws;
    }
  });

  const sorted = players.slice().sort((a,b) => {
    if (stats[b].pts !== stats[a].pts) return stats[b].pts - stats[a].pts;
    const gdA = stats[a].gf - stats[a].ga, gdB = stats[b].gf - stats[b].ga;
    if (gdB !== gdA) return gdB - gdA;
    return stats[b].gf - stats[a].gf;
  });

  const maxPts = Math.max(...sorted.map(p => stats[p].pts), 1);
  const rankCls = ['rank-1','rank-2','rank-3'];
  let html = '';
  sorted.forEach((p, i) => {
    const s = stats[p];
    const gd = s.gf - s.ga;
    const gdStr = gd > 0 ? '+' + gd : '' + gd;
    const gdCls = gd > 0 ? 'gd-pos' : gd < 0 ? 'gd-neg' : '';
    const rc = i < 3 ? rankCls[i] : '';
    const barW = Math.round((s.pts / maxPts) * 80);
    html += '<tr>' +
      '<td class="rank-cell ' + rc + '">' + (i+1) + '</td>' +
      '<td><div class="player-cell">' +
        '<div class="avatar">' + p.slice(0,2).toUpperCase() + '</div>' +
        '<div class="name-wrap"><span>' + p + '</span>' +
          (s.pts > 0 ? '<div class="leader-bar" style="width:' + barW + 'px"></div>' : '') +
        '</div>' +
      '</div></td>' +
      '<td class="right stat-cell">' + s.p + '</td>' +
      '<td class="right stat-cell">' + s.w + '</td>' +
      '<td class="right stat-cell">' + s.l + '</td>' +
      '<td class="right stat-cell ' + gdCls + '">' + (s.p > 0 ? gdStr : '&mdash;') + '</td>' +
      '<td class="right pts-cell">' + s.pts + '</td>' +
    '</tr>';
  });
  document.getElementById('table-body').innerHTML = html;
}

function showTab(tab, e) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.getElementById(tab).classList.add('active');
  e.target.classList.add('active');
}

renderSchedule();
renderTable();
</script>
</body>
</html>
